{
  "globalStyle": {
    "navigationBarBackgroundColor": "@navBgColor",
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "Bearlen AI",
    "backgroundColor": "@bgColor",
    "backgroundTextStyle": "@bgTxtStyle",
    "backgroundColorTop": "@bgColorTop",
    "backgroundColorBottom": "@bgColorBottom",
    "enablePullDownRefresh": false,
    "onReachBottomDistance": 50,
    "animationType": "pop-in",
    "animationDuration": 300
  },
  "pages": [
    // #ifdef MP-WEIXIN
    {
      "path": "pages/index/index",
      "type": "home",
      "name": "home",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    // #endif
    {
      "path": "pages/ai-chat/index",
      "type": "home",
      "name": "aiChat",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "AI 对话",
        "titleNView": {
          "buttons": [
            {
              "type": "none",
              "float": "left",
              "text": "☰",
              "fontSize": "20px",
              "color": "#333333"
            }
          ]
        }
      }
    },
    {
      "path": "pages/customer-mgmt/index",
      "type": "page",
      "name": "customerMgmt",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "客户管理",
        "titleNView": {
          "buttons": [
            {
              "type": "none",
              "float": "left",
              "text": "☰",
              "fontSize": "20px",
              "color": "#333333"
            }
          ]
        }
      }
    },
    {
      "path": "pages/finance/index",
      "type": "page",
      "name": "finance",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "财务",
        "titleNView": {
          "buttons": [
            {
              "type": "none",
              "float": "left",
              "text": "☰",
              "fontSize": "20px",
              "color": "#333333"
            }
          ]
        }
      }
    },
    {
      "path": "pages/login/index",
      "type": "page",
      "name": "login",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "@navBgColor",
        "navigationBarTextStyle": "@navTxtStyle"
      }
    },
    {
      "path": "pages/profile/about-lingxi",
      "type": "page",
      "name": "profileAboutLingxi",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "关于灵犀"
      }
    },
    {
      "path": "pages/profile/account",
      "type": "page",
      "name": "profileAccount",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "账号管理"
      }
    },
    {
      "path": "pages/profile/font-size",
      "type": "page",
      "name": "profileFontSize",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "字号大小"
      }
    },
    {
      "path": "pages/profile/index",
      "type": "page",
      "name": "profile",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/profile/theme",
      "type": "page",
      "name": "profileTheme",
      "layout": "default",
      "style": {
        "navigationBarTitleText": "主题色彩"
      }
    },
    {
      "path": "pages/service/index",
      "type": "page",
      "name": "service",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "客服",
        "titleNView": {
          "buttons": [
            {
              "type": "none",
              "float": "left",
              "text": "☰",
              "fontSize": "20px",
              "color": "#333333"
            }
          ]
        }
      }
    }
  ],
  "subPackages": [
    {
      "root": "subPackages/service",
      "pages": [
        // #ifdef APP || H5
        {
          "path": "returnSort/index",
          "type": "page",
          "name": "returnSort",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "退件整理"
          }
        },
        // #endif
        {
          "path": "returnSort/detail",
          "type": "page",
          "name": "returnSortGoodsDetail",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "货品明细"
          }
        }
      ]
    }
  ],
  "tabBar": {
    "custom": true,
    "customize": true,
    "overlay": true,
    "height": "0",
    "color": "@tabColor",
    "selectedColor": "@tabSelectedColor",
    "backgroundColor": "@tabBgColor",
    "borderStyle": "@tabBorderStyle",
    "list": [
      // GENERATED BY UNI-PAGES, PLATFORM: APP || H5
      {
        "pagePath": "pages/ai-chat/index"
      },
      {
        "pagePath": "pages/finance/index"
      },
      {
        "pagePath": "pages/customer-mgmt/index"
      },
      {
        "pagePath": "pages/service/index"
      }
    ]
  }
}
